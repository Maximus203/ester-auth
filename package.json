{
  "name": "ester",
  "version": "1.0.0",
  "description": "Une application web moderne d'authentification construite avec Express.js (TypeScript), SQLite et Server-Side Rendering (SSR).",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:migrate": "ts-node src/database/migrate.ts",
    "db:seed": "ts-node src/database/seed.ts",
    "db:reset": "ts-node src/database/reset.ts",
    "test": "node scripts/test-application.js",
    "test:watch": "echo \"Tests en mode watch - À implémenter\"",
    "test:coverage": "echo \"Coverage des tests - À implémenter\"",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "express",
    "typescript",
    "authentication",
    "sqlite",
    "ssr"
  ],
  "author": "Votre Nom",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@types/connect-sqlite3": "^0.9.5",
    "@types/express-rate-limit": "^5.1.3",
    "@types/winston": "^2.4.4",
    "bcrypt": "^6.0.0",
    "connect-sqlite3": "^0.9.16",
    "dotenv": "^17.2.0",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.0",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "sqlite3": "^5.1.7",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/node": "^24.0.14",
    "@types/sqlite3": "^3.1.11",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}