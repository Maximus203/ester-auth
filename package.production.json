{
 "name": "ester",
 "version": "1.0.0",
 "description": "Application d'authentification moderne avec Express (TypeScript) + SQLite",
 "main": "dist/app.js",
 "scripts": {
  "dev": "nodemon --exec ts-node src/app.ts",
  "build": "tsc",
  "start": "node dist/app.js",
  "prod": "npm run build && NODE_ENV=production node dist/app.js",
  "test": "node scripts/test-application.js",
  "test:manual": "node scripts/manual-test.js",
  "clean": "rimraf dist",
  "lint": "eslint src/**/*.ts",
  "format": "prettier --write src/**/*.{ts,js}",
  "db:migrate": "node scripts/migrate.js",
  "db:seed": "node scripts/seed.js",
  "logs": "tail -f logs/app.log",
  "health": "curl -f http://localhost:3000/health || exit 1"
 },
 "keywords": [
  "express",
  "typescript",
  "authentication",
  "sqlite",
  "ssr",
  "responsive",
  "security"
 ],
 "author": "Ester Development Team",
 "license": "MIT",
 "dependencies": {
  "express": "^4.18.2",
  "express-session": "^1.17.3",
  "express-validator": "^7.0.1",
  "bcrypt": "^5.1.1",
  "helmet": "^7.1.0",
  "compression": "^1.7.4",
  "express-rate-limit": "^7.1.5",
  "sqlite3": "^5.1.6",
  "ejs": "^3.1.9",
  "dotenv": "^16.3.1",
  "winston": "^3.11.0",
  "cors": "^2.8.5"
 },
 "devDependencies": {
  "@types/node": "^20.10.4",
  "@types/express": "^4.17.21",
  "@types/express-session": "^1.17.10",
  "@types/bcrypt": "^5.0.2",
  "@types/compression": "^1.7.5",
  "typescript": "^5.3.3",
  "nodemon": "^3.0.2",
  "ts-node": "^10.9.1",
  "eslint": "^8.56.0",
  "@typescript-eslint/eslint-plugin": "^6.14.0",
  "@typescript-eslint/parser": "^6.14.0",
  "prettier": "^3.1.1",
  "rimraf": "^5.0.5"
 },
 "engines": {
  "node": ">=18.0.0",
  "npm": ">=8.0.0"
 },
 "repository": {
  "type": "git",
  "url": "https://github.com/your-username/ester.git"
 },
 "bugs": {
  "url": "https://github.com/your-username/ester/issues"
 },
 "homepage": "https://github.com/your-username/ester#readme"
}