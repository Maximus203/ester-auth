<!DOCTYPE html>
<html lang="fr">

<head>
 <meta charset="UTF-8">
 <meta name="viewport" content="width=device-width, initial-scale=1.0">
 <title>
  <%= title || 'Accueil - Ester' %>
 </title>

 <!-- Meta tags SEO -->
 <% if (typeof meta !=='undefined' ) { %>
  <% if (meta.description) { %>
   <meta name="description" content="<%= meta.description %>">
   <% } %>
    <% if (meta.keywords) { %>
     <meta name="keywords" content="<%= meta.keywords %>">
     <% } %>
      <% } %>

       <!-- Favicon -->
       <link rel="icon" type="image/x-icon" href="/favicon.ico">

       <!-- CSS -->
       <link rel="stylesheet" href="/css/main.css">

       <!-- Fonts -->
       <link rel="preconnect" href="https://fonts.googleapis.com">
       <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
       <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

       <!-- Icons -->
       <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
 <!-- Navigation -->
 <%- include('../partials/navigation') %>

  <!-- Messages Flash -->
  <%- include('../partials/flash-messages') %>

   <!-- Contenu principal -->
   <main class="main-content">
    <div class="hero-section">
     <div class="hero-container">
      <div class="hero-content">
       <h1 class="hero-title">
        Bienvenue sur <span class="brand-name">Ester</span>
       </h1>
       <p class="hero-subtitle">
        Une application moderne d'authentification avec interface responsive et sécurisée
       </p>
       <div class="hero-features">
        <div class="feature-item">
         <i class="fas fa-shield-alt feature-icon"></i>
         <span>Sécurité avancée</span>
        </div>
        <div class="feature-item">
         <i class="fas fa-mobile-alt feature-icon"></i>
         <span>Design responsive</span>
        </div>
        <div class="feature-item">
         <i class="fas fa-bolt feature-icon"></i>
         <span>Performance optimale</span>
        </div>
       </div>

       <% if (typeof user==='undefined' || !user) { %>
        <div class="hero-actions">
         <a href="/register" class="btn btn-primary btn-large">
          <i class="fas fa-user-plus"></i>
          Créer un compte
         </a>
         <a href="/login" class="btn btn-secondary btn-large">
          <i class="fas fa-sign-in-alt"></i>
          Se connecter
         </a>
        </div>
        <% } else { %>
         <div class="hero-actions">
          <a href="/dashboard" class="btn btn-primary btn-large">
           <i class="fas fa-tachometer-alt"></i>
           Accéder au Dashboard
          </a>
         </div>
         <% } %>
      </div>

      <div class="hero-image">
       <div class="hero-graphic">
        <div class="graphic-circle circle-1"></div>
        <div class="graphic-circle circle-2"></div>
        <div class="graphic-circle circle-3"></div>
        <div class="graphic-icon">
         <i class="fas fa-star"></i>
        </div>
       </div>
      </div>
     </div>
    </div>

    <!-- Section statistiques -->
    <div class="stats-section">
     <div class="stats-container">
      <h2 class="stats-title">Ester en chiffres</h2>
      <div class="stats-grid">
       <div class="stat-item">
        <div class="stat-number" id="users-count">
         <% if (typeof stats !=='undefined' && stats.users) { %>
          <%= stats.users %>
           <% } else { %>
            0
            <% } %>
        </div>
        <div class="stat-label">Utilisateurs inscrits</div>
        <div class="stat-icon">
         <i class="fas fa-users"></i>
        </div>
       </div>

       <div class="stat-item">
        <div class="stat-number">99.9%</div>
        <div class="stat-label">Disponibilité</div>
        <div class="stat-icon">
         <i class="fas fa-server"></i>
        </div>
       </div>

       <div class="stat-item">
        <div class="stat-number">&lt;50ms</div>
        <div class="stat-label">Temps de réponse</div>
        <div class="stat-icon">
         <i class="fas fa-tachometer-alt"></i>
        </div>
       </div>

       <div class="stat-item">
        <div class="stat-number">100%</div>
        <div class="stat-label">Sécurisé</div>
        <div class="stat-icon">
         <i class="fas fa-shield-alt"></i>
        </div>
       </div>
      </div>
     </div>
    </div>

    <!-- Section fonctionnalités -->
    <div class="features-section">
     <div class="features-container">
      <h2 class="features-title">Fonctionnalités principales</h2>
      <div class="features-grid">
       <div class="feature-card">
        <div class="feature-card-icon">
         <i class="fas fa-user-shield"></i>
        </div>
        <h3 class="feature-card-title">Authentification sécurisée</h3>
        <p class="feature-card-description">
         Système d'authentification robuste avec chiffrement des mots de passe et sessions sécurisées.
        </p>
       </div>

       <div class="feature-card">
        <div class="feature-card-icon">
         <i class="fas fa-chart-line"></i>
        </div>
        <h3 class="feature-card-title">Dashboard personnalisé</h3>
        <p class="feature-card-description">
         Interface utilisateur intuitive avec tableau de bord personnalisé et horloge en temps réel.
        </p>
       </div>

       <div class="feature-card">
        <div class="feature-card-icon">
         <i class="fas fa-cog"></i>
        </div>
        <h3 class="feature-card-title">Gestion de profil</h3>
        <p class="feature-card-description">
         Modification facile du profil utilisateur et gestion sécurisée des mots de passe.
        </p>
       </div>

       <div class="feature-card">
        <div class="feature-card-icon">
         <i class="fas fa-mobile-alt"></i>
        </div>
        <h3 class="feature-card-title">Design responsive</h3>
        <p class="feature-card-description">
         Interface adaptée à tous les appareils : desktop, tablette et mobile.
        </p>
       </div>
      </div>
     </div>
    </div>
   </main>

   <!-- Footer -->
   <%- include('../partials/footer') %>

    <!-- JavaScript -->
    <script src="/js/main.js"></script>
</body>

</html>